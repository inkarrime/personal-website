---
interface Props {
    link: string;
    cover: string;
    title: string;
    description: string;
    tags?: { label: string; type?: 'project' | 'work' | 'personal' | 'design' | 'product' }[];
    icons?: { src: string; alt: string }[];
}

const { cover, link, title, description, tags = [], icons = [] } = Astro.props;
---

<article class="card">
    <a class="link" target="_blank" rel="noopener noreferrer" href={link}>
        <div class="img-container">
            <img class="img" src={cover} alt="Cover">
        </div>
        <div class="content">
            <h3>{title}</h3>
            {tags.length > 0 && (
                    <ul class="tags">
                        {tags.map(tag => (
                                <li class={`tag tag--${tag.type ?? 'project'}`}>
                                    {tag.label}
                                </li>
                        ))}
                    </ul>
            )}

            <p>{description}</p>

            {icons.length > 0 && (
                    <ul class="tool-icons">
                        {icons.map(icon => (
                                <li>
                                    <img class="icon" src={icon.src} alt={icon.alt} title={icon.alt} />
                                </li>
                        ))}
                    </ul>
            )}
        </div>
    </a>
</article>

<style is:global>
    .card {
        .link {
            background-color: var(--bg-light-color);
            border-radius: 0.8rem;
            flex-direction: column;
            padding: 0;
            transition: all 0.3s cubic-bezier(0.645, 0.045, 0.355, 1.000);
            overflow: hidden;
        }
        .link:hover {
            background-color: #122833;
            transform: scale(1.02);
        }
        .img-container {
            width: 100%;
        }
        .img {
            width: inherit;
        }
        .content {
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        h3 {
            font-size: 1.25rem;
            font-weight: 700;
        }
        p {
            font-size: 1rem;
        }

        /* ── Tags ── */
        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
        }
        .tag {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            padding: 3px 10px;
            border-radius: 999px;
            white-space: nowrap;
        }
        .tag--work {
            background-color: rgba(1, 90, 255, 0.15);
            color: var(--accent-light-color);
            border: 1px solid rgba(1, 90, 255, 0.35);
        }
        .tag--project {
            background-color: rgba(169, 197, 241, 0.1);
            color: var(--accent-light-color);
            border: 1px solid rgba(169, 197, 241, 0.25);
        }
        .tag--personal {
            background-color: rgba(244, 241, 210, 0.08);
            color: var(--text-color);
            border: 1px solid rgba(244, 241, 210, 0.2);
        }

        .tag--design {
            background-color: rgba(139, 92, 246, 0.15);
            color: #c4b5fd;
            border: 1px solid rgba(139, 92, 246, 0.35);
        }
        .tag--product {
            background-color: rgba(16, 185, 129, 0.12);
            color: #6ee7b7;
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        /* ── Tool icons ── */
        .tool-icons {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            align-items: center;
        }
        .tool-icons .icon {
            width: 20px;
            height: 20px;
            object-fit: contain;
            opacity: 0.75;
            transition: opacity 0.2s;
        }
        .tool-icons .icon:hover {
            opacity: 1;
        }
    }
</style>