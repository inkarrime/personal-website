---
interface Props {
	text: string;
}
const { text } = Astro.props;
---

<div class="scrolling-banner">
	<div class="scrolling-content">
		<span class="banner-text">{text}</span>
		<span class="banner-text">{text}</span>
		<span class="banner-text">{text}</span>
		<span class="banner-text">{text}</span>
	</div>
</div>

<style>
	.scrolling-banner {
		width: 100%;
		overflow: hidden;
		background-color: #53FC18;
		padding: 0.75rem 0;
		position: relative;
	}

	.scrolling-content {
		display: flex;
		width: max-content;
		animation: scroll-left 20s linear infinite;
	}

	.banner-text {
		color: var(--bg-color);
		font-size: 1.5rem;
		font-weight: 800;
		white-space: nowrap;
		padding: 0 2rem;
	}

	@keyframes scroll-left {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}

	@media screen and (min-width: 820px) {
		.banner-text {
			font-size: 1.75rem;
		}
	}
</style>
